SKU_LENS_ENV=local
SKU_LENS_VERSION=local
SKU_LENS_DATA_DIR=./var/data

MYSQL_DATABASE=sku_lens
MYSQL_USER=sku
MYSQL_PASSWORD=replace-me-url-safe-password
MYSQL_ROOT_PASSWORD=replace-me-root-password

SERVER_BIND_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_WORKERS=2
WEB_BIND_HOST=127.0.0.1
WEB_PORT=3000

SHOPIFY_API_KEY=replace-me
SHOPIFY_API_SECRET=replace-me
SHOPIFY_SCOPES=read_products,read_orders,write_pixels,read_customer_events
SHOPIFY_APP_URL=http://localhost:3000
SHOPIFY_WEBHOOK_BASE_URL=http://localhost:8000

DATABASE_URL=mysql+aiomysql://sku:replace-me-url-safe-password@localhost:3306/sku_lens
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=

SKU_LENS_LOG_LEVEL=INFO
SKU_LENS_INTERNAL_REVIEW=0
INGEST_SHARED_SECRET=replace-me-ingest-secret
INGEST_TOKEN_TTL_SECONDS=300

AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
